# ===== Telegram =====
BOT_TOKEN=               # токен от @BotFather
OWNER_TG_ID=             # твой Telegram user id (единственный, кому всё доступно)
WEBHOOK_SECRET=          # любая длинная случайная строка (для проверки webhook)
PUBLIC_URL=              # https://твой-домен

# ===== База данных =====
DATABASE_URL=sqlite:///./data/money.db

# ===== ФНС =====
FNS_TOKENS_PATH=./data/tokens.json
FNS_PROXY=               # пусто, если /scan работает с US-IP; иначе socks5://user:pass@ru-proxy:1080

# ===== LLM (OpenRouter) =====
OPENROUTER_KEYS=         # бесплатные ключи через запятую (ротация для Gemini)
OPENROUTER_PAID_KEY=     # платный ключ для сложной аналитики
GEMINI_MODEL=google/gemini-2.0-flash-exp:free
PAID_MODEL=google/gemini-2.5-pro

# ===== Бэкап =====
BACKUP_CHAT_ID=          # id приватного канала для бэкапов БД
BACKUP_PASSPHRASE=       # пароль шифрования бэкапа (храни отдельно!)

# ===== Финансы =====
BASE_CURRENCY=RUB
EXPECTED_MONTHLY_INCOME=0
TIMEZONE=Europe/Moscow
APP_ENV=dev
